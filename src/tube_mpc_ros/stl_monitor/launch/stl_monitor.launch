<?xml version="1.0"?>
<launch>
  <!-- ✅ STL Monitor Node (C++ version with Path Tracking support) -->
  <node name="stl_monitor" pkg="stl_monitor" type="stl_monitor_node_cpp" output="screen">
    <!-- STL Formula Configuration -->
    <param name="stl_formula_type" value="path_tracking"/>
    <param name="time_horizon" value="20.0"/>

    <!-- Robustness Parameters -->
    <param name="temperature" value="0.1"/>
    <param name="reachability_threshold" value="0.5"/>
    <param name="safety_threshold" value="0.3"/>

    <!-- Belief Space -->
    <param name="use_belief_space" value="false"/>  <!-- ✅ Disabled for path-tracking: use actual robot position -->
    <param name="num_particles" value="100"/>
    <param name="prediction_horizon" value="2.0"/>
    <param name="prediction_dt" value="0.1"/>
    <param name="uncertainty_penalty" value="0.5"/>

    <!-- Budget -->
    <param name="baseline_requirement" value="0.1"/>
    <param name="decay_rate" value="0.0"/>

    <!-- Monitoring -->
    <param name="update_frequency" value="10.0"/>

    <!-- Logging -->
    <param name="log_enabled" value="true"/>
    <param name="log_file" value="/tmp/stl_monitor_data.csv"/>
    <param name="log_frequency" value="10.0"/>

    <!-- MPC Integration -->
    <param name="constraint_mode" value="soft"/>
    <param name="penalty_weight" value="100.0"/>

    <!-- Visualization -->
    <param name="publish_robustness" value="true"/>
    <param name="publish_boundaries" value="true"/>
  </node>

  <!-- RViz Configuration -->
  <arg name="rviz" default="true"/>
  <node if="$(arg rviz)" name="rviz" pkg="rviz" type="rviz"
        args="-d $(find stl_monitor)/cfg/stl_monitor.rviz"/>
</launch>
