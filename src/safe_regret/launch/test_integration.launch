<?xml version="1.0"?>
<launch>
  <!--
    Integration Test Launch File
    Tests Safe-Regret node with simulated Phase 1-3 data
  -->

  <arg name="test_duration" default="30.0" doc="Test duration in seconds"/>

  <!-- Publish simulated tracking error (Phase 1) -->
  <node name="tracking_error_simulator" pkg="rostopic" type="rostopic"
        args="r /tube_mpc/tracking_error std_msgs/Float64MultiArray
             'data: [0.1, 0.05, 0.15]'
             -r 10"
        output="screen"/>

  <!-- Publish simulated MPC trajectory (Phase 1) -->
  <node name="mpc_trajectory_simulator" pkg="rostopic" type="rostopic"
        args="pub /mpc_trajectory nav_msgs/Path
             '{header: {frame_id: \"map\"}, poses: [{pose: {position: {x: 1.0, y: 0.0}}}]}'
             -r 10"
        output="screen"/>

  <!-- Publish simulated STL robustness (Phase 2) -->
  <node name="stl_robustness_simulator" pkg="rostopic" type="rostopic"
        args="r /stl_robustness std_msgs/Float64 'data: 0.8' -r 10"
        output="screen"/>

  <!-- Publish simulated STL budget (Phase 2) -->
  <node name="stl_budget_simulator" pkg="rostopic" type="rostopic"
        args="r /stl_budget std_msgs/Float64 'data: 0.5' -r 10"
        output="screen"/>

  <!-- Publish simulated DR margins (Phase 3) -->
  <node name="dr_margins_simulator" pkg="rostopic" type="rostopic"
        args="r /dr_margins std_msgs/Float64MultiArray 'data: [0.1, 0.2, 0.15]' -r 10"
        output="screen"/>

  <!-- Publish simulated odometry -->
  <node name="odom_simulator" pkg="rostopic" type="rostopic"
        args="pub /odom nav_msgs/Odometry
             '{header: {frame_id: \"odom\"}, pose: {pose: {position: {x: 1.0, y: 2.0}, orientation: {w: 1.0}}}}'
             -r 10"
        output="screen"/>

  <!-- Safe-Regret Node (Phase 4) -->
  <node name="safe_regret_node" pkg="safe_regret" type="safe_regret_node" output="screen">
    <param name="update_frequency" value="10.0"/>
    <param name="enable_regret_logging" value="false"/>
  </node>

  <!-- Monitor published topics -->
  <node name="topic_monitor" pkg="rostopic" type="rostopic"
        args="list /safe_regret"
        output="screen"
        launch-prefix="bash -c 'sleep 5; echo \"=== Safe-Regret Topics ===\"'"/>

  <!-- Echo reference trajectory -->
  <node name="reference_monitor" pkg="rostopic" type="rostopic"
        args="echo /safe_regret/reference_trajectory --noarr"
        output="screen"
        launch-prefix="bash -c 'sleep 8; echo \"=== Reference Trajectory ===\"'"/>

  <!-- Echo regret metrics -->
  <node name="regret_monitor" pkg="rostopic" type="rostopic"
        args="echo /safe_regret/regret_metrics --noarr"
        output="screen"
        launch-prefix="bash -c 'sleep 10; echo \"=== Regret Metrics ===\"'"/>

  <!-- Auto-kill after test duration -->
  <node pkg="rospy" type="timed_roslaunch" name="timed_roslaunch"
        args="$(arg test_duration) kill_all_nodes"/>

</launch>
