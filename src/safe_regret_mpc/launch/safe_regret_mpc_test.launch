<?xml version="1.0"?>
<launch>
  <!--
    Safe-Regret MPC Complete System Launch

    This launch file starts the complete Safe-Regret MPC system with all features enabled.

    Features:
    - Tube MPC (Phase 1) ✅
    - STL Monitoring (Phase 2) ✅
    - DR Constraint Tightening (Phase 3) ✅
    - Terminal Set (Phase 4) ✅
    - Unified Solver (Phase 5) ✅

    Usage:
      roslaunch safe_regret_mpc safe_regret_mpc.launch

      Optional:
        use_gazebo:=true          # Enable Gazebo simulation (default: true)
        enable_visualization:=true # Enable RViz (default: false to avoid conflicts)
        enable_stl:=true          # Enable STL monitoring (default: true)
  -->

  <!-- ========== Arguments ========== -->
  <!-- Integration Mode -->
  <arg name="enable_safe_regret_integration" default="true"/>
    <!-- true: tube_mpc发布/cmd_vel_raw → safe_regret_mpc处理 → /cmd_vel
         false: tube_mpc直接发布/cmd_vel（独立模式） -->

  <!-- Legacy Controller Mode (deprecated, kept for compatibility) -->
  <arg name="controller_mode" default="INTEGRATION"/>

  <!-- Feature Modules -->
  <arg name="enable_stl" default="false"/>
  <arg name="enable_dr" default="false"/>
  <arg name="enable_terminal_set" default="false"/>
  <arg name="enable_reference_planner" default="false"/>

  <!-- System Configuration -->
  <arg name="enable_visualization" default="true"/>
  <arg name="debug_mode" default="true"/>
  <arg name="controller_frequency" default="20"/>
  <arg name="mpc_steps" default="20"/>
  <arg name="reference_velocity" default="0.5"/>
  <arg name="use_gazebo" default="true"/>

  <!-- ========== Phase 6: Robot Initial Pose at Station S1 (Loading Area - West) ========== -->
  <arg name="x_pos" default="-8.0"/>   <!-- Station S1: X坐标 -->
  <arg name="y_pos" default="0.0"/>    <!-- Station S1: Y坐标 -->
  <arg name="z_pos" default="0.0"/>    <!-- 地面高度 -->
  <arg name="roll" default="0"/>       <!-- 无翻滚 -->
  <arg name="pitch" default="0"/>      <!-- 无俯仰 -->
  <arg name="yaw" default="0.0"/>      <!-- Station S1: 朝向东（正X方向） -->

  <!-- ========== Phase 6: Logistics Task Pickup Point (可变取货点) ========== -->
  <arg name="pickup_x" default="0.0"/>      <!-- 取货点S1: X坐标 (可通过命令行修改) -->
  <arg name="pickup_y" default="-7.0"/>     <!-- 取货点S1: Y坐标 (可通过命令行修改) -->
  <arg name="pickup_yaw" default="0.0"/>    <!-- 取货点S1: 朝向 (弧度) -->

  <!-- ========== Parameters ========== -->
  <rosparam file="$(find safe_regret_mpc)/params/safe_regret_mpc_params.yaml" command="load"/>

  <!-- ========== DR Tightening Node ========== -->
  <group if="$(arg enable_dr)">
    <node name="dr_tightening" pkg="dr_tightening" type="dr_tightening_node" output="screen">
      <!-- DR Parameters -->
      <param name="residual_window_size" value="200"/>
      <param name="residual_dimension" value="3"/>
      <param name="total_risk_delta" value="0.1"/>
      <param name="mpc_horizon" value="20"/>
      <param name="risk_allocation_strategy" value="uniform"/>
      <param name="ambiguity_strategy" value="wasserstein_ball"/>
      <param name="confidence_level" value="0.9"/>
      <param name="tube_radius" value="0.18"/>  <!-- 增加到18cm，提高安全性（原8cm） -->
      <param name="lipschitz_constant" value="1.0"/>
      <param name="safety_buffer" value="0.18"/>  <!-- 增加到18cm，提高安全性（原8cm） -->
      <param name="obstacle_influence_radius" value="1.6"/>  <!-- 增加到1.6m，提高安全性（原1.5m） -->
      <param name="update_rate" value="10.0"/>
      <param name="enable_visualization" value="true"/>
      <param name="enable_debug_output" value="false"/>
      <param name="log_to_csv" value="false"/>

      <!-- Topics -->
      <remap from="tracking_error" to="/mpc/tracking_error"/>
      <remap from="mpc_trajectory" to="/mpc_trajectory"/>
      <remap from="odom" to="/odom"/>
      <remap from="cmd_vel" to="/cmd_vel"/>
      <remap from="dr_margins" to="/dr_margins"/>
      <remap from="terminal_set" to="/dr_terminal_set"/>
    </node>
  </group>

  <!-- ========== Reference Planner & Regret Analysis ========== -->
  <group if="$(arg enable_reference_planner)">
    <node name="safe_regret" pkg="safe_regret" type="safe_regret_node"
          output="screen" required="false"
          respawn="false" respawn_delay="5">
      <!-- Regret Analysis Parameters -->
      <param name="enable_regret_logging" value="true"/>
      <param name="regret_log_file" value="/tmp/safe_regret_data.csv"/>
      <param name="regret_metrics_topic" value="/safe_regret/regret_metrics"/>
      <param name="reference_trajectory_topic" value="/safe_regret/reference_trajectory"/>

      <!-- Algorithm Configuration -->
      <param name="no_regret_algorithm" value="omd"/>
      <param name="tube_radius" value="0.18"/>
      <param name="L_lipschitz" value="1.0"/>
      <param name="infeasibility_penalty" value="1000.0"/>

      <!-- Topic Remapping -->
      <remap from="system_state" to="/safe_regret_mpc/state"/>
      <remap from="mpc_trajectory" to="/mpc_trajectory"/>
      <remap from="tracking_error" to="/tube_mpc/tracking_error"/>
      <remap from="odom" to="/odom"/>
    </node>
  </group>

  <!-- ========== Gazebo Simulation ========== -->
  <group if="$(arg use_gazebo)">
    <include file="$(find tube_mpc_ros)/launch/nav_gazebo_test.launch">
      <!-- Position -->
      <arg name="x_pos" value="$(arg x_pos)"/>
      <arg name="y_pos" value="$(arg y_pos)"/>
      <arg name="z_pos" value="$(arg z_pos)"/>
      <arg name="roll" value="$(arg roll)"/>
      <arg name="pitch" value="$(arg pitch)"/>
      <arg name="yaw" value="$(arg yaw)"/>

      <!-- Controller: IMPORTANT - must use tube_mpc for integration to work -->
      <arg name="controller" value="tube_mpc"/>

      <!-- Safe-Regret MPC Integration Mode -->
      <arg name="enable_safe_regret_integration" value="$(arg enable_safe_regret_integration)"/>
    </include>
  </group>

  <!-- ========== STL Monitor ========== -->
  <group if="$(arg enable_stl)">
    <node name="stl_monitor" pkg="stl_monitor" type="stl_monitor_node.py" output="screen">
      <!-- STL Formula Configuration -->
      <param name="stl_formula_type" value="reachability"/>
      <param name="time_horizon" value="20.0"/>

      <!-- Robustness Parameters -->
      <param name="temperature" value="0.1"/>
      <param name="reachability_threshold" value="0.5"/>
      <param name="safety_threshold" value="0.3"/>

      <!-- Belief Space -->
      <param name="use_belief_space" value="false"/>
      <param name="num_particles" value="100"/>
      <param name="prediction_horizon" value="2.0"/>
      <param name="prediction_dt" value="0.1"/>
      <param name="uncertainty_penalty" value="0.5"/>

      <!-- Budget -->
      <param name="baseline_requirement" value="0.1"/>
      <param name="decay_rate" value="0.0"/>

      <!-- Monitoring -->
      <param name="update_frequency" value="10.0"/>

      <!-- Logging -->
      <param name="log_enabled" value="true"/>
      <param name="log_file" value="/tmp/stl_monitor_data.csv"/>
      <param name="log_frequency" value="10.0"/>

      <!-- MPC Integration -->
      <param name="constraint_mode" value="soft"/>
      <param name="penalty_weight" value="100.0"/>

      <!-- Visualization -->
      <param name="publish_robustness" value="true"/>
      <param name="publish_boundaries" value="true"/>
    </node>
  </group>

  <!-- ========== Safe-Regret MPC Node (Integration Center) ========== -->
  <node name="safe_regret_mpc" pkg="safe_regret_mpc" type="safe_regret_mpc_node"
        output="screen" required="false"
        respawn="false" respawn_delay="5">

    <!-- Integration Mode Parameters -->
    <param name="enable_integration_mode" value="$(arg enable_safe_regret_integration)"/>
    <param name="controller_mode" value="INTEGRATION"/>
    <param name="enable_stl_constraints" value="$(arg enable_stl)"/>
    <param name="enable_dr_constraints" value="$(arg enable_dr)"/>
    <param name="enable_terminal_set" value="$(arg enable_terminal_set)"/>
    <param name="debug_mode" value="$(arg debug_mode)"/>
    <param name="controller_frequency" value="$(arg controller_frequency)"/>
    <param name="publish_frequency" value="10.0"/>
    <param name="mpc_steps" value="$(arg mpc_steps)"/>
    <param name="mpc_ref_vel" value="$(arg reference_velocity)"/>
    <param name="enable_visualization" value="$(arg enable_visualization)"/>

    <!-- Subscribed topics -->
    <remap from="odom" to="/odom"/>
    <remap from="global_plan" to="/move_base/GlobalPlanner/plan"/>
    <remap from="goal" to="/move_base_simple/goal"/>

    <!-- Tube MPC data (integration mode only) -->
    <remap from="cmd_vel_raw" to="/cmd_vel_raw"/>  <!-- Raw command from tube_mpc -->
    <remap from="mpc_trajectory" to="/mpc_trajectory"/>  <!-- Trajectory from tube_mpc -->
    <remap from="tube_mpc/tracking_error" to="/tube_mpc/tracking_error"/>  <!-- Error from tube_mpc -->

    <!-- STL topics -->
    <remap from="stl_robustness" to="/stl_monitor/robustness"/>

    <!-- DR topics -->
    <remap from="dr_margins" to="/dr_margins"/>
    <remap from="terminal_set" to="/dr_terminal_set"/>

    <!-- Published topics -->
    <remap from="cmd_vel" to="/cmd_vel"/>  <!-- Final command to robot -->
    <remap from="system_state" to="/safe_regret_mpc/state"/>
    <remap from="metrics" to="/safe_regret_mpc/metrics"/>
    <remap from="mpc_trajectory" to="/mpc_trajectory"/>  <!-- Forwarded from tube_mpc -->
    <remap from="tube_boundaries" to="/tube_boundaries"/>

  </node>

  <!-- ========== RViz Visualization ========== -->
  <!-- RViz由tube_mpc_ros的launch文件启动，避免重复窗口 -->

  <!-- ========== Auto Navigation Goal (Phase 6: S1 → S2 Logistics Task) ========== -->
  <node name="auto_nav_goal" pkg="safe_regret_mpc" type="auto_nav_goal.py" output="screen"
        launch-prefix="bash -c 'sleep 5; $0 $@'">
    <!-- 取货点 S1 (Pickup Station) - 可通过命令行参数修改 -->
    <param name="pickup_x" value="$(arg pickup_x)"/>    <!-- 取货点X坐标 -->
    <param name="pickup_y" value="$(arg pickup_y)"/>    <!-- 取货点Y坐标 -->
    <param name="pickup_yaw" value="$(arg pickup_yaw)"/><!-- 取货点朝向 -->

    <!-- 卸货点 S2 (Delivery Station) - 固定坐标 -->
    <param name="delivery_x" value="8.0"/>    <!-- 卸货点X坐标 (固定) -->
    <param name="delivery_y" value="0.0"/>    <!-- 卸货点Y坐标 (固定) -->
    <param name="delivery_yaw" value="0.0"/>  <!-- 卸货点朝向 -->

    <!-- 目标到达阈值 -->
    <param name="goal_radius" value="0.5"/>   <!-- 到达判定半径 (m) -->
  </node>

  <!-- ========== Random Obstacles (启动时随机放置障碍物) ========== -->
  <node name="random_obstacles" pkg="safe_regret_mpc" type="random_obstacles.py" output="screen"
        launch-prefix="bash -c 'sleep 2; $0 $@'">
    <param name="safety_radius" value="0.7"/>                      <!-- 目标点安全半径 (m) -->
    <param name="robot_safety_radius" value="1.6"/>                <!-- 小车周围安全半径 (m) -->
    <param name="robot_start_x" value="$(arg x_pos)"/>             <!-- 小车初始X坐标 -->
    <param name="robot_start_y" value="$(arg y_pos)"/>             <!-- 小车初始Y坐标 -->
  </node>

</launch>
