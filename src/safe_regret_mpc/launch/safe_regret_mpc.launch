<?xml version="1.0"?>
<launch>
  <!--
    Safe-Regret MPC Complete System Launch

    This launch file starts the complete Safe-Regret MPC system integrating:
    - Tube MPC (Phase 1)
    - STL Monitoring (Phase 2)
    - DR Constraint Tightening (Phase 3)
    - Terminal Set (Phase 4)
    - Unified Solver (Phase 5)

    Usage:
      roslaunch safe_regret_mpc safe_regret_mpc.launch
  -->

  <!-- ========== Arguments ========== -->
  <arg name="controller_mode" default="SAFE_REGRET_MPC"
        doc="Controller mode: TUBE_MPC, STL_MPC, DR_MPC, SAFE_REGRET_MPC"/>

  <arg name="enable_stl" default="true"
        doc="Enable STL monitoring and constraints"/>

  <arg name="enable_dr" default="true"
        doc="Enable distributionally robust constraints"/>

  <arg name="enable_terminal_set" default="true"
        doc="Enable terminal set constraints"/>

  <arg name="enable_visualization" default="true"
        doc="Enable RViz visualization"/>

  <arg name="debug_mode" default="false"
        doc="Enable debug output"/>

  <arg name="controller_frequency" default="20"
        doc="Control loop frequency (Hz)"/>

  <arg name="mpc_steps" default="20"
        doc="MPC prediction horizon"/>

  <arg name="reference_velocity" default="0.5"
        doc="Reference velocity (m/s)"/>

  <!-- ========== Parameters ========== -->
  <rosparam file="$(find safe_regret_mpc)/params/safe_regret_mpc_params.yaml"
             command="load"/>

  <!-- Override with command-line arguments -->
  <param name="controller_mode" value="$(arg controller_mode)"/>
  <param name="enable_stl_constraints" value="$(arg enable_stl)"/>
  <param name="enable_dr_constraints" value="$(arg enable_dr)"/>
  <param name="enable_terminal_set" value="$(arg enable_terminal_set)"/>
  <param name="debug_mode" value="$(arg debug_mode)"/>
  <param name="controller_frequency" value="$(arg controller_frequency)"/>
  <param name="mpc_steps" value="$(arg mpc_steps)"/>
  <param name="mpc_ref_vel" value="$(arg reference_velocity)"/>

  <!-- ========== Launch Dependencies ========== -->

  <!-- STL Monitor (if enabled) -->
  <group if="$(arg enable_stl)">
    <include file="$(find stl_monitor)/launch/stl_monitor.launch">
      <arg name="enable" value="true"/>
      <arg name="publish_frequency" value="10"/>
    </include>
  </group>

  <!-- DR Tightening (if enabled) -->
  <group if="$(arg enable_dr)">
    <include file="$(find dr_tightening)/launch/dr_tube_mpc_integrated.launch">
      <arg name="enable_terminal_set" value="$(arg enable_terminal_set)"/>
    </include>
  </group>

  <!-- ========== Safe-Regret MPC Node ========== -->
  <node name="safe_regret_mpc" pkg="safe_regret_mpc" type="safe_regret_mpc_node"
        output="screen" required="true">

    <!-- Subscribed topics -->
    <remap from="odom" to="/odom"/>
    <remap from="global_plan" to="/move_base/TrajectoryPlannerROS/global_plan"/>
    <remap from="goal" to="/move_base_simple/goal"/>

    <!-- STL topics -->
    <remap from="stl_robustness" to="/stl_monitor/robustness"/>

    <!-- DR topics -->
    <remap from="dr_margins" to="/dr_margins"/>
    <remap from="terminal_set" to="/dr_terminal_set"/>

    <!-- Published topics -->
    <remap from="cmd_vel" to="/cmd_vel"/>
    <remap from="system_state" to="/safe_regret_mpc/state"/>
    <remap from="metrics" to="/safe_regret_mpc/metrics"/>
    <remap from="mpc_trajectory" to="/mpc_trajectory"/>
    <remap from="tube_boundaries" to="/tube_boundaries"/>

  </node>

  <!-- ========== RViz (if visualization enabled) ========== -->
  <group if="$(arg enable_visualization)">
    <node name="rviz" pkg="rviz" type="rviz"
          args="-d $(find safe_regret_mpc)/rviz/safe_regret_mpc.rviz"
          required="false"/>

    <!-- Visualization markers -->
    <node name="safe_regret_viz" pkg="safe_regret_mpc" type="visualization_node"
          output="screen" if="$(arg enable_visualization)"/>
  </group>

  <!-- ========== Optional: Gazebo Simulation ========== -->
  <arg name="use_gazebo" default="false"
        doc="Launch Gazebo simulation"/>

  <group if="$(arg use_gazebo)">
    <include file="$(find tube_mpc_ros)/launch/nav_gazebo.launch">
      <arg name="world_name" value="$(find tube_mpc_ros)/worlds/empty.world"/>
    </include>
  </group>

</launch>
